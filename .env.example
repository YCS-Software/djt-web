# EV Charging Platform Environment Variables
# Copy this file to .env and update the values

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=evcharging
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Secrets (generate secure random strings)
JWT_ACCESS_SECRET=your_very_long_and_secure_access_token_secret_at_least_32_chars
JWT_REFRESH_SECRET=your_very_long_and_secure_refresh_token_secret_at_least_32_chars

# Razorpay (get from Razorpay Dashboard)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Application
APP_URL=https://your-domain.com
CORS_ORIGIN=https://your-domain.com

# OCPP
OCPP_PORT=9000
OCPP_PATH=/ocpp

# Email (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=noreply@example.com

# SMS (optional)
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=EVCHARGE
